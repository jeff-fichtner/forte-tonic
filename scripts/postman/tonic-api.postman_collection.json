{
  "info": {
    "name": "Tonic API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Public",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/health"
          }
        },
        {
          "name": "Version",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/version"
          }
        },
        {
          "name": "App Configuration",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/configuration"
          }
        },
        {
          "name": "Auth - Admin (6-digit code)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data) {",
                  "  if (res.data.admin) pm.environment.set('adminId', res.data.admin.id);",
                  "  pm.environment.set('accessCode', pm.environment.get('adminAccessCode'));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/access-code",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accessCode\": \"{{adminAccessCode}}\",\n  \"loginType\": \"employee\"\n}"
            }
          }
        },
        {
          "name": "Auth - Instructor (6-digit code)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data) {",
                  "  if (res.data.instructor) pm.environment.set('instructorId', res.data.instructor.id);",
                  "  pm.environment.set('accessCode', pm.environment.get('instructorAccessCode'));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/access-code",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accessCode\": \"{{instructorAccessCode}}\",\n  \"loginType\": \"employee\"\n}"
            }
          }
        },
        {
          "name": "Auth - Parent (10-digit phone)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data) {",
                  "  if (res.data.parent) pm.environment.set('parentId', res.data.parent.id);",
                  "  pm.environment.set('accessCode', pm.environment.get('parentPhone'));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/access-code",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accessCode\": \"{{parentPhone}}\",\n  \"loginType\": \"parent\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Registrations",
      "item": [
        {
          "name": "Create Registration (private lesson)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data.id) {",
                  "  pm.environment.set('registrationId', res.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/registrations",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-access-code", "value": "{{accessCode}}" },
              { "key": "x-login-type", "value": "employee" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studentId\": \"{{studentId}}\",\n  \"instructorId\": \"{{instructorId}}\",\n  \"registrationType\": \"private\",\n  \"day\": \"Monday\",\n  \"startTime\": \"14:00\",\n  \"length\": 30,\n  \"instrument\": \"Piano\",\n  \"roomId\": \"ROOM1\",\n  \"transportationType\": \"parent\",\n  \"trimester\": \"{{trimester}}\"\n}"
            }
          }
        },
        {
          "name": "Create Registration (group class)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data.id) {",
                  "  pm.environment.set('registrationId', res.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/registrations",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-access-code", "value": "{{accessCode}}" },
              { "key": "x-login-type", "value": "employee" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studentId\": \"{{studentId}}\",\n  \"registrationType\": \"group\",\n  \"classId\": \"G018\",\n  \"transportationType\": \"parent\",\n  \"trimester\": \"{{trimester}}\"\n}"
            }
          }
        },
        {
          "name": "Delete Registration",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/registrations/{{trimester}}/{{registrationId}}",
            "header": [
              { "key": "x-access-code", "value": "{{adminAccessCode}}" },
              { "key": "x-login-type", "value": "employee" }
            ]
          }
        },
        {
          "name": "Update Reenrollment Intent",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/registrations/{{registrationId}}/intent",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-access-code", "value": "{{parentPhone}}" },
              { "key": "x-login-type", "value": "parent" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"intent\": \"keep\"\n}",
              "description": "intent must be one of: keep, drop, change"
            }
          }
        }
      ]
    },
    {
      "name": "Attendance",
      "item": [
        {
          "name": "Mark Attendance",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/attendance",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-access-code", "value": "{{accessCode}}" },
              { "key": "x-login-type", "value": "employee" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"registrationId\": \"{{registrationId}}\",\n  \"week\": 1,\n  \"schoolYear\": \"2025-2026\",\n  \"trimester\": \"{{trimester}}\"\n}"
            }
          }
        },
        {
          "name": "Get Attendance Summary",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/attendance/summary/{{registrationId}}?schoolYear=2025-2026&trimester={{trimester}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "attendance", "summary", "{{registrationId}}"],
              "query": [
                { "key": "schoolYear", "value": "2025-2026" },
                { "key": "trimester", "value": "{{trimester}}" }
              ]
            },
            "header": [
              { "key": "x-access-code", "value": "{{accessCode}}" },
              { "key": "x-login-type", "value": "employee" }
            ]
          }
        }
      ]
    },
    {
      "name": "Admin Tabs",
      "item": [
        {
          "name": "Master Schedule",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/admin/tabs/master-schedule/{{trimester}}",
            "header": [
              { "key": "x-access-code", "value": "{{adminAccessCode}}" },
              { "key": "x-login-type", "value": "employee" }
            ]
          }
        },
        {
          "name": "Wait List",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/admin/tabs/wait-list/{{trimester}}",
            "header": [
              { "key": "x-access-code", "value": "{{adminAccessCode}}" },
              { "key": "x-login-type", "value": "employee" }
            ]
          }
        },
        {
          "name": "Registration Tab",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/admin/tabs/registration/{{trimester}}",
            "header": [
              { "key": "x-access-code", "value": "{{adminAccessCode}}" },
              { "key": "x-login-type", "value": "employee" }
            ]
          }
        },
        {
          "name": "Clear Cache",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/admin/clear-cache",
            "header": [
              { "key": "x-access-code", "value": "{{adminAccessCode}}" },
              { "key": "x-login-type", "value": "employee" }
            ]
          }
        }
      ]
    },
    {
      "name": "Instructor Tabs",
      "item": [
        {
          "name": "Directory",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/instructor/tabs/directory",
            "header": [
              { "key": "x-access-code", "value": "{{instructorAccessCode}}" },
              { "key": "x-login-type", "value": "employee" }
            ]
          }
        },
        {
          "name": "Weekly Schedule",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/instructor/tabs/weekly-schedule/{{trimester}}?instructorId={{instructorId}}",
              "host": ["{{baseUrl}}"],
              "path": [
                "api",
                "instructor",
                "tabs",
                "weekly-schedule",
                "{{trimester}}"
              ],
              "query": [{ "key": "instructorId", "value": "{{instructorId}}" }]
            },
            "header": [
              { "key": "x-access-code", "value": "{{instructorAccessCode}}" },
              { "key": "x-login-type", "value": "employee" }
            ]
          }
        }
      ]
    },
    {
      "name": "Parent Tabs",
      "item": [
        {
          "name": "Contact",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/parent/tabs/contact/{{trimester}}?parentId={{parentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "parent", "tabs", "contact", "{{trimester}}"],
              "query": [{ "key": "parentId", "value": "{{parentId}}" }]
            },
            "header": [
              { "key": "x-access-code", "value": "{{parentPhone}}" },
              { "key": "x-login-type", "value": "parent" }
            ]
          }
        },
        {
          "name": "Weekly Schedule",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data.students && res.data.students.length) {",
                  "  pm.environment.set('studentId', res.data.students[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/parent/tabs/weekly-schedule/{{trimester}}?parentId={{parentId}}",
              "host": ["{{baseUrl}}"],
              "path": [
                "api",
                "parent",
                "tabs",
                "weekly-schedule",
                "{{trimester}}"
              ],
              "query": [{ "key": "parentId", "value": "{{parentId}}" }]
            },
            "header": [
              { "key": "x-access-code", "value": "{{parentPhone}}" },
              { "key": "x-login-type", "value": "parent" }
            ]
          }
        },
        {
          "name": "Registration Tab",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('response includes availableTimeSlots', () => {",
                  "  pm.expect(res.data).to.have.property('availableTimeSlots');",
                  "  pm.expect(typeof res.data.availableTimeSlots).to.equal('object');",
                  "});",
                  "if (res.success && res.data && res.data.students && res.data.students.length) {",
                  "  pm.environment.set('studentId', res.data.students[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/parent/tabs/registration/{{trimester}}?parentId={{parentId}}",
              "host": ["{{baseUrl}}"],
              "path": [
                "api",
                "parent",
                "tabs",
                "registration",
                "{{trimester}}"
              ],
              "query": [
                { "key": "parentId", "value": "{{parentId}}" },
                { "key": "excludeRegistrationId", "value": "", "description": "Optional. Registration ID to exclude from conflict detection (modify-registration flow)", "disabled": true }
              ]
            },
            "header": [
              { "key": "x-access-code", "value": "{{parentPhone}}" },
              { "key": "x-login-type", "value": "parent" }
            ]
          }
        }
      ]
    },
    {
      "name": "Feedback",
      "item": [
        {
          "name": "Submit Feedback",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/feedback",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-access-code", "value": "{{accessCode}}" },
              { "key": "x-login-type", "value": "employee" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Test feedback message\",\n  \"state\": {\n    \"currentUser\": { \"email\": \"test@forte.edu\" },\n    \"timestamp\": \"2025-01-01T00:00:00Z\",\n    \"url\": \"/\",\n    \"currentSection\": \"registration\",\n    \"selectedTrimester\": \"fall\"\n  }\n}"
            }
          }
        }
      ]
    }
  ]
}
